PORT=3001
NODE_ENV=development

# API + Auth
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
JWT_SECRET=
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
ADMIN_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# WhatsApp Cloud API (OTP)
# Permanent token from Meta app
WHATSAPP_ACCESS_TOKEN=
# Phone number ID from WhatsApp Manager
WHATSAPP_PHONE_NUMBER_ID=
# Approved template name with one body variable for code, e.g. tsenabe_otp_code
WHATSAPP_TEMPLATE_NAME=
# Language code used by the approved template
WHATSAPP_TEMPLATE_LANGUAGE=fr